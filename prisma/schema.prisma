generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String?
  credits      Int            @default(100)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  projects     Project[]
  assets       Asset[]
  jobs         GenerationJob[]
  ledger       CreditLedger[]
}

model Project {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  templateId String?
  template   Template? @relation(fields: [templateId], references: [id])
  status     String   @default("draft")
  step       Int      @default(0)
  settings   String   @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  assets     Asset[]
  jobs       GenerationJob[]
}

model Asset {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  type         String
  source       String   @default("upload")
  storageUrl   String
  metadata     String   @default("{}")
  parentAssetId String?
  createdAt    DateTime @default(now())
}

model GenerationJob {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  kind           String
  provider       String?
  params         String   @default("{}")
  status         String   @default("pending")
  creditEstimate Int      @default(0)
  creditCharged  Int      @default(0)
  error          String?
  resultAssetId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CreditLedger {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId        String?
  delta        Int
  balanceAfter Int
  reason       String
  createdAt    DateTime @default(now())
}

model Template {
  id             String    @id @default(cuid())
  industry       String
  name           String
  description    String?
  defaultParams  String    @default("{}")
  promptScaffold String?
  createdAt      DateTime  @default(now())
  projects       Project[]
}
