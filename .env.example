# Database — use Neon Postgres (local + Vercel). Get URL from neon.tech → Connect.
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"

# Public URL for share links (required on Vercel — use your deployment URL)
# Local dev: http://localhost:3000
# Vercel:    https://your-project.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

NEXT_PUBLIC_APP_NAME="AI Video Studio"

# AI providers (optional — mock mode works without keys)
# FAL_KEY=""
